    "# Importando as funções dos arquivos criados\n",
    "from cadastrar import cadastrar_aluno\n",
    "from media import calcular_media\n",
    "from verificar import verificar_situacao\n",
    "\n",
    "# Executando o sistema\n",
    "nome, n1, n2 = cadastrar_aluno()\n",
    "media_final = calcular_media(n1, n2)\n",
    "situacao = verificar_situacao(media_final)\n",
    "\n",
    "# Exibindo os resultados conforme o exemplo da tarefa\n",
    "print(f\"\\nAluno: {nome}\"),       
    "print(f\"Média: {media_final}\"),   
    "print(f\"Situação: {situacao}\"),  
   ]
